<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - SaaS Panel</title>
    <link rel="stylesheet" href="assets/style.css">
</head>
<body>
    <div class="dashboard">
        <aside class="sidebar">
            <h3>🚀 SaaS Panel</h3>
            <nav>
                <a href="#" class="active">Dashboard</a>
                <a href="#" id="createServerBtn">Create Server</a>
                <a href="#" class="logout-btn">Logout</a>
            </nav>
        </aside>
        
        <main class="main-content">
            <h1>Welcome, <span id="userName"></span></h1>
            
            <div class="card">
                <div class="card-header">
                    <h2>Your Servers</h2>
                </div>
                <div id="serversList">
                    <div class="loading">Loading servers...</div>
                </div>
            </div>
        </main>
    </div>

    <!-- Create Server Modal -->
    <div id="createServerModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Create New Server</h3>
                <span class="modal-close" onclick="closeModal('createServerModal')">&times;</span>
            </div>
            <form id="createServerForm">
                <div class="form-group">
                    <label>Server Name</label>
                    <input type="text" id="serverName" required>
                </div>
                <div class="form-group">
                    <label>Server Type</label>
                    <select id="serverType" required>
                        <option value="minecraft">Minecraft Server</option>
                        <option value="bot">WhatsApp Bot</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Create Server</button>
            </form>
        </div>
    </div>

    <script>
        let currentUser = null;
        
        async function loadDashboard() {
            try {
                const data = await apiCall('/user.js');
                currentUser = data.user;
                document.getElementById('userName').textContent = currentUser.fullname;
                
                // Load servers
                const serversHtml = data.servers.map(server => `
                    <div class="card">
                        <div class="card-header">
                            <h3>${server.name}</h3>
                            <button onclick="deleteServer('${server.id}')" class="btn btn-danger">Delete</button>
                        </div>
                        <p>Type: ${server.type}</p>
                        <p>Status: ${server.status || 'Running'}</p>
                        <button onclick="openPanel('${server.id}')" class="btn btn-primary">Open Panel</button>
                    </div>
                `).join('');
                
                document.getElementById('serversList').innerHTML = serversHtml || '<p>No servers yet. Create one!</p>';
            } catch (error) {
                showNotification(error.message);
            }
        }
        
        async function deleteServer(serverId) {
            if (confirm('Are you sure you want to delete this server?')) {
                try {
                    await apiCall('/delete-server.js', {
                        method: 'POST',
                        body: JSON.stringify({ serverId })
                    });
                    showNotification('Server deleted successfully', 'success');
                    loadDashboard();
                } catch (error) {
                    showNotification(error.message);
                }
            }
        }
        
        function openPanel(serverId) {
            // Open Pterodactyl panel
            window.open(`/panel/${serverId}`, '_blank');
        }
        
        // Create server form
        document.getElementById('createServerForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const name = document.getElementById('serverName').value;
            const type = document.getElementById('serverType').value;
            
            try {
                await apiCall('/create-server.js', {
                    method: 'POST',
                    body: JSON.stringify({ name, type })
                });
                showNotification('Server created successfully!', 'success');
                closeModal('createServerModal');
                loadDashboard();
                document.getElementById('createServerForm').reset();
            } catch (error) {
                showNotification(error.message);
            }
        });
        
        document.getElementById('createServerBtn')?.addEventListener('click', () => {
            openModal('createServerModal');
        });
        
        loadDashboard();
    </script>
    <script src="assets/script.js"></script>
</body>
</html>