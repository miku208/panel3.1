const mysql = require('mysql2');

const pool = mysql.createPool({
    host: process.env.DB_HOST || 'shuttle.proxy.rlwy.net',
    user: process.env.DB_USER || 'root',
    password: process.env.DB_PASSWORD || 'hgcuWnKIrukiWhtSXMBGsULvcXiOFPJi',
    database: process.env.DB_NAME || 'railway',
    port: process.env.DB_PORT || 34953,
    waitForConnections: true,
    connectionLimit: 10,
    queueLimit: 0
});
const promisePool = pool.promise();

// Query helper
const query = async (sql, params) => {
    try {
        const [rows] = await promisePool.execute(sql, params);
        return rows;
    } catch (error) {
        console.error('Database error:', error);
        throw error;
    }
};

// Get single row
const getOne = async (sql, params) => {
    const rows = await query(sql, params);
    return rows[0] || null;
};

// Insert and get id
const insert = async (sql, params) => {
    const [result] = await promisePool.execute(sql, params);
    return result.insertId;
};

// Update
const update = async (sql, params) => {
    const [result] = await promisePool.execute(sql, params);
    return result.affectedRows;
};

// Get Pterodactyl settings
const getPterodactylSettings = async () => {
    let settings = await getOne('SELECT * FROM api_settings WHERE id = 1');
    if (!settings) {
        await insert('INSERT INTO api_settings (id, ptero_api_key, ptero_url) VALUES (1, "", "")', []);
        settings = { ptero_api_key: '', ptero_url: '' };
    }
    return settings;
};

module.exports = {
    query,
    getOne,
    insert,
    update,
    getPterodactylSettings
};